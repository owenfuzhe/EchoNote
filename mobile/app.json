{
  "expo": {
    "name": "EchoNote",
    "slug": "echonote-lmlutm0a1zkx7c8mwqv6-",
    "owner": "crispytofus-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "backgroundColor": "#fcfaf5",
    "scheme": "echonote",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fcfaf5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crispyideas.echonote",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
