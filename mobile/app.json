        "NSMicrophoneUsageDescription": "EchoNote 需要使用麦克风来记录你的语音想法并生成笔记。"
      }
    },
    "android": {
      "package": "com.crispyideas.echonote",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fcfaf5"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "EchoNote 需要使用麦克风来记录你的语音想法并生成笔记。",
          "speechRecognitionPermission": "EchoNote 需要语音识别权限来把你的语音转换成可编辑文本。"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9ba735e3-7610-4a1f-ba2e-863da439234f"
      }
    }
  }
